<Window x:Class="StandReminder.ReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StandReminder"
        Width="380" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize">

    <Border x:Name="Card" CornerRadius="16" Background="{StaticResource CardBrush}"
            BorderThickness="1.5" BorderBrush="{StaticResource BorderBrush}"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.45"/>
        </Border.Effect>

        <StackPanel Margin="24,22,24,22">
            <StackPanel Orientation="Horizontal">
                <Border x:Name="EmojiBadge" Width="56" Height="56" CornerRadius="14"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="EmojiText" FontSize="30" FontFamily="Segoe UI Emoji"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock x:Name="SubtitleText" FontSize="13" Margin="0,4,0,0"
                               Foreground="{StaticResource SubTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="AcceptButton" Grid.Column="0" Style="{StaticResource PrimaryButton}"
                        Click="Accept_Click"/>
                <Button Grid.Column="2" Style="{StaticResource GhostButton}" Content="+5 min"
                        Click="Snooze_Click"/>
            </Grid>
        </StackPanel>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
