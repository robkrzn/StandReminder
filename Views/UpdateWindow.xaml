<Window x:Class="StandReminder.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StandReminder"
        Width="440" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="True"
        ResizeMode="NoResize"
        FontFamily="Segoe UI, Segoe UI Emoji">

    <Border CornerRadius="16" Background="{StaticResource CardBrush}"
            BorderThickness="1.5" BorderBrush="{StaticResource BorderBrush}"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.45"/>
        </Border.Effect>

        <StackPanel Margin="24,22,24,22">

            <!-- Header -->
            <StackPanel Orientation="Horizontal">
                <Border Width="56" Height="56" CornerRadius="14" VerticalAlignment="Center"
                        Background="#2646C28E">
                    <TextBlock Text="🚀" FontSize="30" FontFamily="Segoe UI Emoji"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock x:Name="VersionText" FontSize="13" Margin="0,4,0,0"
                               Foreground="{StaticResource SubTextBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Release notes -->
            <TextBlock x:Name="NotesHeader" FontSize="12" FontWeight="SemiBold" Margin="2,18,0,6"
                       Foreground="{StaticResource SubTextBrush}"/>
            <Border CornerRadius="10" Background="{StaticResource InputBrush}"
                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                <Border.Resources>
                    <!-- slim dark scrollbar, matching the settings dropdown -->
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True" Width="8">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageUpCommand"
                                                          Focusable="False" IsTabStop="False">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageDownCommand"
                                                          Focusable="False" IsTabStop="False">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Focusable="False">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border CornerRadius="3" Margin="1.5"
                                                                Background="{StaticResource BorderBrush}"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Border.Resources>
                <ScrollViewer x:Name="NotesScroller" MaxHeight="220" Margin="4"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TextBlock x:Name="NotesText" Margin="12,10" TextWrapping="Wrap"
                               FontSize="12.5" LineHeight="18"
                               Foreground="{StaticResource TextBrush}"/>
                </ScrollViewer>
            </Border>

            <TextBlock Margin="2,8,0,0">
                <Hyperlink x:Name="PageLink" Click="OpenPage_Click"
                           Foreground="{StaticResource AccentSitBrush}" TextDecorations="None">
                    <Run x:Name="PageLinkText"/>
                </Hyperlink>
            </TextBlock>

            <!-- Download progress (hidden until updating) -->
            <StackPanel x:Name="ProgressPanel" Margin="0,18,0,0" Visibility="Collapsed">
                <Border x:Name="Track" Height="6" CornerRadius="3"
                        Background="{StaticResource InputBrush}">
                    <Border x:Name="Fill" Height="6" CornerRadius="3" Width="0"
                            HorizontalAlignment="Left"
                            Background="{StaticResource AccentStandBrush}"/>
                </Border>
                <TextBlock x:Name="StatusText" FontSize="12.5" Margin="2,8,0,0"
                           Foreground="{StaticResource SubTextBrush}"/>
            </StackPanel>

            <!-- Buttons -->
            <Grid x:Name="ButtonsRow" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="SkipButton" Grid.Column="0" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Left" Padding="12,10" FontSize="12.5"
                        BorderThickness="0" Click="Skip_Click"/>
                <Button x:Name="LaterButton" Grid.Column="1" Style="{StaticResource GhostButton}"
                        Click="Later_Click"/>
                <Button x:Name="UpdateButton" Grid.Column="3" Style="{StaticResource PrimaryButton}"
                        Click="Update_Click"/>
            </Grid>
        </StackPanel>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
