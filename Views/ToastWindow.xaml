<Window x:Class="StandReminder.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StandReminder"
        Width="360" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize"
        FontFamily="Segoe UI, Segoe UI Emoji">

    <Border CornerRadius="14" Background="{StaticResource CardBrush}"
            BorderThickness="1.5" BorderBrush="{StaticResource BorderBrush}"
            Margin="12" Cursor="Hand" MouseLeftButtonUp="Dismiss">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.45"/>
        </Border.Effect>

        <StackPanel Orientation="Horizontal" Margin="18,16,22,16">
            <Border x:Name="EmojiBadge" Width="44" Height="44" CornerRadius="12"
                    VerticalAlignment="Center">
                <TextBlock x:Name="EmojiText" FontSize="24" FontFamily="Segoe UI Emoji"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontSize="14.5" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock x:Name="MessageText" FontSize="12.5" Margin="0,3,0,0" MaxWidth="248"
                           Foreground="{StaticResource SubTextBrush}" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
