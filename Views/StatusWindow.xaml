<Window x:Class="StandReminder.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StandReminder"
        Width="320" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize">

    <Border CornerRadius="14" Background="{StaticResource CardBrush}"
            BorderThickness="1.5" BorderBrush="{StaticResource BorderBrush}"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.45"/>
        </Border.Effect>

        <StackPanel Margin="20,18,20,18">

            <!-- Header: state + gear -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="EmojiText" FontSize="28" FontFamily="Segoe UI Emoji"
                               VerticalAlignment="Center"/>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="StateText" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock x:Name="ElapsedText" FontSize="12" Margin="0,2,0,0"
                                   Foreground="{StaticResource SubTextBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Button x:Name="GearButton" Grid.Column="1" Style="{StaticResource GhostButton}"
                        Padding="8,6" VerticalAlignment="Top" Click="Gear_Click"
                        ToolTip="Nastavenia">
                    <TextBlock Text="&#xE713;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                </Button>
            </Grid>

            <!-- Progress -->
            <StackPanel x:Name="ProgressPanel" Margin="0,16,0,0">
                <Grid>
                    <Border x:Name="Track" Height="8" CornerRadius="4" Background="#2A2F3F"/>
                    <Border x:Name="Fill" Height="8" CornerRadius="4" Width="0"
                            HorizontalAlignment="Left"
                            Background="{StaticResource AccentSitBrush}"/>
                </Grid>
                <TextBlock x:Name="RemainingText" FontSize="13" Margin="0,8,0,0"
                           Foreground="{StaticResource SubTextBrush}"/>
            </StackPanel>

            <!-- Actions -->
            <Button x:Name="SwitchButton" Style="{StaticResource GhostButton}"
                    Content="Zmeniť pozíciu teraz" Margin="0,14,0,0"
                    Click="Switch_Click"/>

        </StackPanel>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.15"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
