<Window x:Class="StandReminder.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StandReminder – Nastavenia"
        Width="420" SizeToContent="Height"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <StackPanel Margin="28,24,28,24">

        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="20"
                       Foreground="{StaticResource AccentSitBrush}"
                       VerticalAlignment="Center" Margin="0,2,10,0"/>
            <TextBlock x:Name="HeaderText" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Intervals card -->
        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock x:Name="IntervalsHeader" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>

                <TextBlock x:Name="SitLabel" FontSize="13" Foreground="{StaticResource SubTextBrush}"/>
                <Slider x:Name="SitSlider" Style="{StaticResource DarkSlider}"
                        Minimum="10" Maximum="120" TickFrequency="5"
                        ValueChanged="Sliders_ValueChanged" Margin="0,4,0,12"/>

                <TextBlock x:Name="StandLabel" FontSize="13" Foreground="{StaticResource SubTextBrush}"/>
                <Slider x:Name="StandSlider" Style="{StaticResource DarkSlider}"
                        Minimum="5" Maximum="60" TickFrequency="5"
                        ValueChanged="Sliders_ValueChanged" Margin="0,4,0,4"/>

                <TextBlock x:Name="RatioHint"
                           FontSize="11" Foreground="{StaticResource SubTextBrush}"
                           Opacity="0.7" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Work hours card -->
        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock x:Name="WorkHoursHeader" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="FromLabel" FontSize="13" Foreground="{StaticResource SubTextBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="StartCombo" Style="{StaticResource DarkCombo}"/>
                    <TextBlock x:Name="ToLabel" FontSize="13" Foreground="{StaticResource SubTextBrush}"
                               VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <ComboBox x:Name="EndCombo" Style="{StaticResource DarkCombo}"/>
                </StackPanel>
                <TextBlock x:Name="WorkHint"
                           FontSize="11" Foreground="{StaticResource SubTextBrush}"
                           Opacity="0.7" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Options card -->
        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,20">
            <StackPanel>
                <CheckBox x:Name="SoundCheck" Style="{StaticResource DarkCheckBox}"
                          Margin="0,0,0,8"/>
                <CheckBox x:Name="AutostartCheck" Style="{StaticResource DarkCheckBox}"/>
                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <TextBlock x:Name="LangLabel" FontSize="13"
                               Foreground="{StaticResource SubTextBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="LangCombo" Style="{StaticResource DarkCombo}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="SaveButton" Grid.Column="0" Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource AccentSitBrush}" Click="Save_Click"/>
            <Button x:Name="CancelButton" Grid.Column="2" Style="{StaticResource GhostButton}"
                    Click="Cancel_Click"/>
        </Grid>

    </StackPanel>
</Window>
